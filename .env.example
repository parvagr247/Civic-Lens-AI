# ==============================================================================
# CivicLens AI - Environment Variable Templates
# ==============================================================================
# Copy this file to '.env' and populate with your actual values.
# NEVER commit the '.env' file or any real keys to Git.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. System Ports and Profiles
# ------------------------------------------------------------------------------
PORT=9526
SPRING_PROFILES_ACTIVE=dev

# ------------------------------------------------------------------------------
# 2. Gemini AI Integration (Spring AI / ChatClient / Embabel)
# ------------------------------------------------------------------------------
# Get your Gemini API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ------------------------------------------------------------------------------
# 3. Firebase Integration (Firestore and Cloud Storage)
# ------------------------------------------------------------------------------
# Path to the service account JSON key file (relative to backend folder or absolute path)
# Default points to the git-ignored local service account location.
FIREBASE_CONFIG_PATH=classpath:firebase-service-account.json

# URL of the Firebase Realtime/Firestore DB if required
FIREBASE_DATABASE_URL=

# Name of your Firebase Storage bucket (e.g. your-project.firebasestorage.app)
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_name_here
