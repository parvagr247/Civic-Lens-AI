# CivicLens AI - Environment Configuration Example Template
# Copy this file to .env on the deployment host and populate the actual secrets.

# Google Gemini Credentials (required for AI analytics)
GEMINI_API_KEY=

# Target Gemini model (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Firebase Cloud Storage Bucket URL (optional, leave blank to disable Storage)
FIREBASE_STORAGE_BUCKET=civiclens-prod-storage.firebasestorage.app

# Firebase RTDB Database URL (optional, currently unused)
FIREBASE_DATABASE_URL=

# Allowed Origins list for CORS (comma-separated, default: localhost, port 80)
# Overwrite this with http://<YOUR_VM_PUBLIC_IP> in production
APP_ALLOWED_ORIGINS=http://localhost:5173
