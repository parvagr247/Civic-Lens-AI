# ==============================================================================
# CivicLens AI - Frontend GitIgnore Exclusions
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Dependency and Build Folders
# ------------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
*.local

# ------------------------------------------------------------------------------
# 2. Local Environment Secrets (CRITICAL)
# ------------------------------------------------------------------------------
.env
.env.local
.env.development
.env.production
.env.development.local
.env.production.local

# ------------------------------------------------------------------------------
# 3. IDE Configurations and Workspace Metadata
# ------------------------------------------------------------------------------
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.eslintcache

# ------------------------------------------------------------------------------
# 4. Logs and Diagnostic Outputs
# ------------------------------------------------------------------------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------------------------
# 5. OS-Specific Metadata
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
